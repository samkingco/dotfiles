// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "diff_view_style": "unified",
  "cli_default_open_behavior": "new_window",
  "default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "right",
    "button": false,
  },
  "ssh_connections": [
    {
      "host": "100.103.11.115",
      "username": "dev",
      "args": [],
      "projects": [
        {
          "paths": ["/home/dev"],
        },
        {
          "paths": ["/home/dev/code/kaiho"],
        },
      ],
      "nickname": "personal-sandbox",
    },
  ],
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
    "oxlint": {
      "initialization_options": {
        "settings": {
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "run": "onType",
          "unusedDisableDirectives": "deny",
        },
      },
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": null,
        },
      },
    },
  },
  "git_panel": {
    "dock": "right",
    "tree_view": false,
    "button": true,
    "starts_open": true,
  },
  "prettier": {
    "allowed": true,
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
  },
  "show_edit_predictions": true,
  "base_keymap": "Atom",
  "agent": {
    "enabled": false,
    "button": false,
    "single_file_review": true,
    "default_profile": "write",
    "profiles": {
      "code-writer": {
        "name": "Code Writer",
        "tools": {
          "terminal": true,
          "copy-path": true,
          "create-file": true,
          "delete-path": true,
          "diagnostics": true,
          "find-replace-file": true,
          "edit-files": true,
          "fetch": true,
          "list-directory": true,
          "move-path": true,
          "now": true,
          "path-search": true,
          "read-file": true,
          "regex-search": true,
          "thinking": true,
        },
        "context_servers": {},
      },
    },
    "dock": "left",
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
    },
  },
  "auto_update": true,
  "buffer_font_size": 12,
  "buffer_font_family": "CommitMonoV143",
  "calls": {
    "mute_on_join": true,
  },
  "collaboration_panel": {
    "dock": "right",
    "button": false,
  },
  "soft_wrap": "editor_width",
  "preferred_line_length": 80,
  "languages": {
    "JavaScript": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt",
          },
        },
        {
          "code_action": "source.fixAll.oxc",
        },
      ],
    },
    "JSX": {
      "format_on_save": "on",
