  "format_on_save": "on",
  "formatter": "auto",
  "code_actions_on_format": {},
  "project_panel": {
    "button": true,
    "starts_open": true,
    "file_icons": false,
    "folder_icons": false,
    "indent_size": 12,
    "dock": "right",
  },
  "show_call_status_icon": false,
  "relative_line_numbers": "disabled",
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "tab_size": 2,
  "theme": "Vesper",
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false,
    "code_actions": false,
  },
  "tab_bar": {
