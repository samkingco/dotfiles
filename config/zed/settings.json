// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "ssh_connections": [
    {
      "host": "100.103.11.115",
      "username": "dev",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/dev"
          ]
        },
        {
          "paths": [
            "/home/dev/code/kaiho"
          ]
        }
      ],
      "nickname": "personal-sandbox"
    }
  ],
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    }
  },
  "git_panel": {
    "tree_view": false
  },
  "prettier": {
    "allowed": true
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "eager",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    },
    "enabled_in_text_threads": false
  },
  "show_edit_predictions": true,
  "base_keymap": "VSCode",
  "agent": {
    "single_file_review": true,
    "default_profile": "write",
    "profiles": {
      "code-writer": {
        "name": "Code Writer",
        "tools": {
          "terminal": true,
          "copy-path": true,
          "create-file": true,
          "delete-path": true,
          "diagnostics": true,
          "find-replace-file": true,
          "edit-files": true,
          "fetch": true,
          "list-directory": true,
          "move-path": true,
          "now": true,
          "path-search": true,
          "read-file": true,
          "regex-search": true,
          "thinking": true
        },
        "context_servers": {}
      }
    },
    "dock": "left",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4"
    }
  },
  "auto_update": true,
  "buffer_font_size": 12,
  "buffer_font_family": "CommitMonoV143",
  "calls": {
    "mute_on_join": true
  },
  "chat_panel": {
    "button": "never"
  },
  "notification_panel": {
    "button": false
  },
  "collaboration_panel": {
    "button": false
  },
  "soft_wrap": "preferred_line_length",
  "preferred_line_length": 100,
  "languages": {
    "TSX": {
      "show_edit_predictions": true
    },
    "Plain Text": {
      "show_edit_predictions": false
    }
  },
  "format_on_save": "on",
  "formatter": "prettier",
  "code_actions_on_format": {
    "source.fixAll.eslint": true
  },
  "project_panel": {
    "file_icons": false,
    "folder_icons": false,
    "indent_size": 12,
    "dock": "right"
  },
  "show_call_status_icon": false,
  "relative_line_numbers": "enabled",
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "tab_size": 2,
  "theme": "Vesper",
  "toolbar": {
    "quick_actions": false
  },
  "ui_font_size": 14,
  "ui_font_family": "CommitMonoV143",
  "bottom_dock_layout": "left_aligned",
  "experimental.theme_overrides": {
    "border": "#1a1a1a",
    "editor.active_wrap_guide": "#1a1a1a",
    "editor.indent_guide": "#1a1a1a",
    "panel.indent_guide": "#1a1a1a"
  }
}
